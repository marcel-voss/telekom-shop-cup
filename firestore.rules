rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Telekom Shop Cup
    // Live-Tabelle liest oeffentlich; Schreiben ueber Admin-Passcode.
    match /shops/{shopId} {
      allow read: if true;
      allow write: if true;
    }

    // News-Eintraege: oeffentlich lesbar, schreiben/loeschen ueber Admin.
    match /news/{newsId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
