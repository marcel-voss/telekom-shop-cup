rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Telekom Shop Cup
    // Die Live-Tabelle (index.html) liest oeffentlich.
    // Schreiben ist im Web-Client moeglich (Schutz erfolgt ueber den
    // Admin-Passcode in admin.html). Wenn du hartes Schreibverbot willst,
    // siehe Variante unten.
    match /shops/{shopId} {
      allow read: if true;
      allow write: if true;
    }
  }
}

// -----------------------------------------------------------------
// OPTIONAL – haertere Variante (empfohlen, wenn moeglich):
// Schreiben nur fuer eingeloggte Nutzer (Firebase Authentication).
// Dann muesste admin.html zusaetzlich einen Firebase-Login bekommen.
//
//   match /shops/{shopId} {
//     allow read: if true;
//     allow write: if request.auth != null;
//   }
//
// Fuer das kurze 9-Tage-Event reicht in der Regel die Passcode-Loesung
// oben voellig aus.
